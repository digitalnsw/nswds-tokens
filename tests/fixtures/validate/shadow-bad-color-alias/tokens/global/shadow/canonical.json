{
  "box-shadow": {
    "bad": {
      "$type": "shadow",
      "$value": {
        "offsetX": {
          "value": 0,
          "unit": "px"
        },
        "offsetY": {
          "value": 0,
          "unit": "px"
        },
        "blur": {
          "value": 0,
          "unit": "px"
        },
        "spread": {
          "value": 1,
          "unit": "px"
        },
        "color": "{border-width.thin}"
      }
    }
  }
}
