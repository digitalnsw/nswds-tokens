exports[`built output snapshots > dist/tailwind/colors/semantic/hex.css 1`] = `
"@theme inline {
  --color-success-50: var(--success-50);
  --color-success-100: var(--success-100);
  --color-success-150: var(--success-150);
  --color-success-200: var(--success-200);
  --color-success-250: var(--success-250);
  --color-success-300: var(--success-300);
  --color-success-350: var(--success-350);
  --color-success-400: var(--success-400);
  --color-success-450: var(--success-450);
  --color-success-500: var(--success-500);
