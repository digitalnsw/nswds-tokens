exports[`built output snapshots > dist/tailwind/colors/themes/data-visualisation/rgb.css 1`] = `
"@theme {
  --color-ember-50: var(--ember-50);
  --color-ember-100: var(--ember-100);
  --color-ember-150: var(--ember-150);
  --color-ember-200: var(--ember-200);
  --color-ember-250: var(--ember-250);
  --color-ember-300: var(--ember-300);
