{
  "name": "@nswds/tokens",
  "version": "2.32.0",
  "description": "NSW Application Design System Design Tokens",
  "homepage": "https://github.com/digitalnsw/nswds-tokens#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/digitalnsw/nswds-tokens.git"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "semantic-release": "semantic-release",
    "lint": "npx eslint . ",
    "format": "npx prettier --write .",
    "postversion": "node scripts/sync-package-lock-version.mjs",
    "copy-styles": "node scripts/copy-styles.mjs",
    "build": "tsup src/index.ts --format esm,cjs --dts --target esnext --treeshake --clean",
    "check:dist": "node scripts/check-dist.mjs",
    "smoke:package-surface": "node scripts/smoke-package-surface.mjs",
    "check:version-sync": "node scripts/check-release-metadata.mjs",
    "test:tokens": "vitest run --globals",
    "sync-tokens-to-figma": "tsx scripts/sync_tokens_to_figma.ts",
    "sync-figma-to-tokens": "tsx scripts/sync_figma_to_tokens.ts"
  },
  "tsup": {
    "entry": [
      "src/index.ts"
    ],
    "splitting": false,
    "sourcemap": true,
    "clean": true,
    "loader": {
      ".css": "text",
      ".scss": "text",
      ".less": "text",
      ".js": "js",
      ".ts": "ts"
    },
    "external": [
      "*.css",
      "*.scss",
      "*.less"
    ],
    "onSuccess": "npm run copy-styles"
  },
  "author": "NSW Design System",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./brand/*": "./dist/brand/*",
    "./css/*": "./dist/css/*",
    "./figma/*": "./dist/figma/*",
    "./js/*": "./dist/js/*",
    "./json/*": "./dist/json/*",
    "./less/*": "./dist/less/*",
    "./scss/*": "./dist/scss/*",
    "./tailwind/*": "./dist/tailwind/*",
    "./tokens/*": "./dist/tokens/*",
    "./ts/*": "./dist/ts/*",
    "./prism.css": "./dist/css/prism/prism.css"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "@eslint/js": "^9.23.0",
    "@figma/rest-api-spec": "^0.33.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.3",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@types/culori": "^4.0.1",
    "@types/node": "^22.13.17",
    "css-loader": "^7.1.2",
    "eslint": "^9.23.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-prettier": "^5.2.4",
    "globals": "^16.0.0",
    "less": "^4.2.2",
    "less-loader": "^12.2.0",
    "prettier": "^3.5.3",
    "sass": "^1.86.1",
    "sass-loader": "^16.0.5",
    "semantic-release": "^25.0.3",
    "style-loader": "^4.0.0",
    "ts-node": "^10.9.2",
    "tsup": "^8.0.2",
    "tsx": "^4.20.5",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.28.0",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "axios": "^1.16.0",
    "culori": "^4.0.2",
    "dotenv": "^17.3.1"
  }
}
