            "ALL_SCOPES"
          ],
          "codeSyntax": {
            "WEB": "var(--z-index-modal)"
          }
        }
      }
    },
    "popover": {
      "$type": "number",
      "$value": 1400,
      "$description": "Popovers anchored to a trigger, above modals.",
      "$extensions": {
        "com.figma": {
          "hiddenFromPublishing": false,
          "scopes": [
