{
  "z-index": {
    "base": {
      "$type": "number",
      "$value": 0,
      "$description": "Base stacking level (0) — default in-flow content.",
      "$extensions": {
        "com.figma": {
          "hiddenFromPublishing": false,
          "scopes": [
            "ALL_SCOPES"
          ],
          "codeSyntax": {
            "WEB": "var(--z-index-base)"
          }
        }
      }
    },
    "dropdown": {
      "$type": "number",
      "$value": 1000,
      "$description": "Dropdown menus and select popups.",
      "$extensions": {
        "com.figma": {
          "hiddenFromPublishing": false,
          "scopes": [
            "ALL_SCOPES"
          ],
          "codeSyntax": {
            "WEB": "var(--z-index-dropdown)"
          }
        }
      }
    },
    "sticky": {
      "$type": "number",
      "$value": 1100,
      "$description": "Sticky elements that pin on scroll (headers, toolbars).",
      "$extensions": {
        "com.figma": {
          "hiddenFromPublishing": false,
          "scopes": [
            "ALL_SCOPES"
          ],
          "codeSyntax": {
